# Google Places API (New) — for live reviews in the Welcome section
# Get your API key: https://console.cloud.google.com/apis/credentials
# Enable "Places API (New)" in your Google Cloud project
GOOGLE_PLACES_API_KEY=

# Find your Place ID: https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_PLACE_ID=

# Current RMS — live product catalog + rental-inquiry form writes
# In production these are set in Vercel. Catalog reads work with read-only
# scope; the rental-inquiry form (POST /api/rental-inquiry) requires a token
# with WRITE scope to create Member + Opportunity records.
CURRENT_RMS_SUBDOMAIN=
CURRENT_RMS_API_KEY=

# Rental Inquiry — set to 1 locally so the form posts validate + log the
# constructed RMS payloads but skip the actual writes. Leave unset in prod.
RENTAL_INQUIRY_DRY_RUN=
