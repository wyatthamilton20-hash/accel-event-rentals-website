# Google Places API (New) — for live reviews in the Welcome section
# Get your API key: https://console.cloud.google.com/apis/credentials
# Enable "Places API (New)" in your Google Cloud project
GOOGLE_PLACES_API_KEY=

# Find your Place ID: https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_PLACE_ID=

# Current RMS — live product catalog
# Only needed locally to run `npm run sync-products`; in production, these are
# set in Vercel. The site will render with placeholders if missing.
CURRENT_RMS_SUBDOMAIN=
CURRENT_RMS_API_KEY=

# Mailchimp — newsletter signups
# Set in Vercel for production. If unset, the /api/newsletter route returns
# 503 and the UI shows a friendly "not configured yet" message.
# API key format: <hex>-<dc>, e.g. "abc123...-us14"
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
MAILCHIMP_DC=

# Quote flow
QUOTE_TEST_MODE=true               # set to "false" only when going live
QUOTE_NOTIFY_EMAILS=               # comma-separated, e.g. "sales@accelrentals.com,ops@accelrentals.com"

# Email provider (none configured by default — uses ConsoleEmailProvider)
EMAIL_PROVIDER=console             # console | resend | smtp | postmark — only "console" implemented today
RESEND_API_KEY=
POSTMARK_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Current RMS write-back (Phase C — keep off until staff are ready)
RMS_WRITE_ENABLED=false
RMS_WRITE_DRY_RUN=true             # only used when RMS_WRITE_ENABLED=true
